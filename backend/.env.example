# SEGURO backend — environment example. Copy to .env and adjust.
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Custom auth (we own this — no third-party auth provider)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=900          # seconds (15 min)
REFRESH_TOKEN_TTL_DAYS=7

# Lockout policy
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15

# Face-capture encryption key (32 bytes hex = 64 chars). Demo only.
FACE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# NOTE: database intentionally not wired yet — backend runs on an in-memory store.
# When ready: add DATABASE_URL (Supabase Postgres) and swap InMemoryStore for Prisma.
