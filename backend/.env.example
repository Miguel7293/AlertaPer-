# DenunciaPE backend — copy to .env and fill in.
PORT=3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://127.0.0.1:5173

# --- Supabase Postgres (Prisma) ---
# Supabase → Project Settings → Database → Connection string.
# DATABASE_URL = pooled connection (port 6543, add ?pgbouncer=true). Used by the app at runtime.
# DIRECT_URL   = direct connection (port 5432). Used by `prisma db pull` / migrations.
# Replace [PASSWORD] and [PROJECT-REF] with your values.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Supabase Storage (evidencias: fotos / videos) ---
# Crea un bucket PÚBLICO llamado "evidencias" en Supabase → Storage.
# SUPABASE_URL = Project Settings → API → Project URL (https://<ref>.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY = Project Settings → API → service_role (¡secreto! solo backend)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=evidencias

# --- Custom auth (we own this — no third-party auth provider) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_DAYS=7

# --- Face-capture encryption key (32 bytes hex = 64 chars). Demo only. ---
FACE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Email verification (optional in local dev) ---
# If SMTP_* is not configured, the API keeps demo mode and returns devCode.
MAIL_APP_NAME=DenunciaPE
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM="DenunciaPE <tu_correo@gmail.com>"
